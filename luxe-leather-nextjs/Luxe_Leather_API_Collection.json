{
  "info": {
    "name": "Luxe Leather API - Comprehensive Test Suite",
    "description": "Comprehensive Postman collection testing all CRUD operations, including pagination, filtering, and bulk operations (simulated via multiple sequential deletes) for the Luxe Leather API. Deletes are placed at the very end to prevent premature data removal. Covers EVERY endpoint discovered in app/api.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. READ Operations (GET) - with Pagination & Filtering",
      "item": [
        {
          "name": "Get Analytics",
          "request": { "method": "GET", "url": "{{base_url}}/analytics" }
        },
        {
          "name": "Get Audit Logs (Paginated & Filtered)",
          "request": { "method": "GET", "url": "{{base_url}}/audit-logs?tableName=products&page=1&limit=5" }
        },
        {
          "name": "Get Categories",
          "request": { "method": "GET", "url": "{{base_url}}/categories" }
        },
        {
          "name": "Get Contact Messages",
          "request": { "method": "GET", "url": "{{base_url}}/contact" }
        },
        {
          "name": "Get Coupons (Storefront Validate)",
          "request": { "method": "GET", "url": "{{base_url}}/coupons?code=POSTMAN10" }
        },
        {
          "name": "Get Coupons (Admin)",
          "request": { "method": "GET", "url": "{{base_url}}/coupons/admin" }
        },
        {
          "name": "Get Customers (Paginated & Search)",
          "request": { "method": "GET", "url": "{{base_url}}/customers?search=john&page=1&limit=10&includeInactive=true" }
        },
        {
          "name": "Get Media",
          "request": { "method": "GET", "url": "{{base_url}}/media" }
        },
        {
          "name": "Get Migrate (Run Migrations)",
          "request": { "method": "GET", "url": "{{base_url}}/migrate" }
        },
        {
          "name": "Get Nav Items",
          "request": { "method": "GET", "url": "{{base_url}}/nav-items" }
        },
        {
          "name": "Get Orders (Paginated & Filtered)",
          "request": { "method": "GET", "url": "{{base_url}}/orders?status=PENDING&page=1&limit=5" }
        },
        {
          "name": "Get Products (Paginated & Sorted)",
          "request": { "method": "GET", "url": "{{base_url}}/products?category=Bags&sortBy=price-low&limit=5&includeInactive=true" }
        },
        {
          "name": "Get Custom Requests (Paginated & Filtered)",
          "request": { "method": "GET", "url": "{{base_url}}/requests?status=NEW&page=1&limit=10" }
        },
        {
          "name": "Get Reviews",
          "request": { "method": "GET", "url": "{{base_url}}/reviews" }
        },
        {
          "name": "Get Settings",
          "request": { "method": "GET", "url": "{{base_url}}/settings" }
        },
        {
          "name": "Get Shipping Zones",
          "request": { "method": "GET", "url": "{{base_url}}/shipping-zones" }
        }
      ]
    },
    {
