  "orders": {
    "required": [
      "id",
      "customer_id",
      "status",
      "subtotal",
      "shipping",
      "total",
      "createdAt",
      "updatedAt",
      "isDeleted"
    ],
    "properties": {
      "id": {
        "description": "Note:\nThis is a Primary Key.<pk/>",
        "format": "uuid",
        "type": "string"
      },
      "customer_id": {
        "description": "Note:\nThis is a Foreign Key to `customers.id`.<fk table='customers' column='id'/>",
        "format": "uuid",
        "type": "string"
      },
      "status": {
        "default": "PENDING",
        "enum": [
          "PENDING",
          "PROCESSING",
          "SHIPPED",
          "DELIVERED",
          "CANCELLED"
        ],
        "format": "public.\"OrderStatus\"",
        "type": "string"
      },
      "subtotal": {
        "format": "double precision",
        "type": "number"
      },
      "shipping": {
        "default": 0,
        "format": "double precision",
        "type": "number"
      },
      "total": {
        "format": "double precision",
        "type": "number"
      },
      "notes": {
        "description": "Customer notes from checkout form",
        "format": "text",
        "type": "string"
      },
      "createdAt": {
        "default": "CURRENT_TIMESTAMP",
        "format": "timestamp without time zone",
        "type": "string"
      },
      "updatedAt": {
        "format": "timestamp without time zone",
        "type": "string"
      },
      "stripe_session_id": {
        "description": "Stripe Checkout Session ID (not used in Elements flow, kept for flexibility)",
        "format": "text",
        "type": "string"
      },
      "stripe_payment_intent_id": {
        "description": "Stripe Payment Intent ID (pi_...)",
        "format": "text",
        "type": "string"
      },
      "payment_status": {
        "default": "unpaid",
        "description": "unpaid | paid | failed | refunded",
        "format": "character varying",
        "maxLength": 50,
        "type": "string"
      },
      "isDeleted": {
        "default": false,
        "format": "boolean",
        "type": "boolean"
      },
      "order_number": {
        "format": "text",
        "type": "string"
      }
    },
    "type": "object"
  },
